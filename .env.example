# SolarX Environment Variables - Example
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ================================================================
# AI Integration (Groq)
# ================================================================
# SECURITY: This key is embedded in the JS bundle (EXPO_PUBLIC_).
# For production, proxy Groq requests through a Supabase Edge Function.
# See: src/lib/groq.ts for details.
EXPO_PUBLIC_GROQ_API_KEY=gsk_your_groq_api_key_here

# ================================================================
# Supabase Configuration
# ================================================================
# SECURITY: The anon key is safe to expose - it is protected by RLS.
# The URL is not sensitive.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
